# ================================================
# HPL SHARES - ENVIRONMENT VARIABLES
# RENAME THIS FILE TO: .env.local
# NEVER commit .env.local to GitHub
# ================================================

# --- FIREBASE CLIENT (Public - safe to expose) ---
NEXT_PUBLIC_FIREBASE_API_KEY=PASTE_HERE
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=PASTE_HERE
NEXT_PUBLIC_FIREBASE_PROJECT_ID=PASTE_HERE
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=PASTE_HERE
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=PASTE_HERE
NEXT_PUBLIC_FIREBASE_APP_ID=PASTE_HERE

# --- FIREBASE ADMIN SDK (Private - server only) ---
# Get from Firebase Console > Project Settings > Service Accounts > Generate New Private Key
FIREBASE_ADMIN_PROJECT_ID=PASTE_HERE
FIREBASE_ADMIN_CLIENT_EMAIL=PASTE_HERE
# For private key: copy the full key including -----BEGIN/END----- lines, replace newlines with \n
FIREBASE_ADMIN_PRIVATE_KEY="PASTE_HERE"

# --- NEXTAUTH SECRET (generate with: openssl rand -base64 32) ---
NEXTAUTH_SECRET=PASTE_A_RANDOM_32_CHARACTER_STRING_HERE
NEXTAUTH_URL=http://localhost:3000

# --- SITE ---
NEXT_PUBLIC_SITE_URL=https://hplshares.in
NEXT_PUBLIC_SITE_NAME=HPL Shares
NEXT_PUBLIC_INSTAGRAM=https://instagram.com/hpl_shares
NEXT_PUBLIC_YOUTUBE=https://youtube.com/@thecybermandotco
